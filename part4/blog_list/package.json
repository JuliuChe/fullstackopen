{
  "name": "blog_list",
  "version": "1.0.0",
  "description": "blog list information that allows users to save information about interestings blogs they have stumbled across on the internet. For each blog, we will have author, title, URL and number of upvotes from users of that application",
  "license": "MIT",
  "author": "Julien Chevalley",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "start": "cross-env NODE_ENV=production node index.js",
    "dev": "cross-env NODE_ENV=development node --watch index.js",
    "lint": "eslint .",
    "test": "cross-env NODE_ENV=test node --test  --test-concurrency=1",
    "test:only": "cross-env NODE_ENV=test node --test --test-only",
    "test:name": "cross-env NODE_ENV=test node --test --test-name-pattern"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.23",
    "mongoose": "^9.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "supertest": "^7.2.2"
  }
}
